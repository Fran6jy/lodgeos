# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_TOKEN=put-your-botfather-token-here

# ── LLM: text + vision (OpenRouter is the fallback / default) ──
OPENROUTER_API_KEY=sk-or-...
# Optional: if set, Anthropic is tried first, OpenRouter as fallback.
# ANTHROPIC_API_KEY=sk-ant-...
# Optional model overrides:
# OPENROUTER_MODEL=openai/gpt-oss-20b:free
# OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free

# ── Voice transcription ───────────────────────────────────
WHISPER_MODE=local            # local (faster-whisper) | cloud
WHISPER_LOCAL_MODEL=base      # tiny | base | small | medium | large-v3
# WHISPER_LANGUAGE=en         # language hint (improves accuracy)
# WHISPER_PROMPT=...          # vocabulary bias (default already includes naira etc.)
# Cloud mode (offload transcription, lighter RAM):
# WHISPER_MODE=cloud
# WHISPER_CLOUD_API_KEY=your-groq-or-openai-key
# WHISPER_CLOUD_BASE_URL=https://api.groq.com/openai/v1
# WHISPER_CLOUD_MODEL=whisper-large-v3

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_BASE_URL=https://lodgeos.example.com   # public URL users open (must be HTTPS)
DASHBOARD_ROOT=0              # 0 = disable single-user "/" route (multi-user safe)
DASHBOARD_TTL=3600           # dashboard link lifetime in seconds

# ── Branding ──────────────────────────────────────────────
BRAND_NAME=LodgeOS

# ── Donations (optional) ──────────────────────────────────
# Your PayPal.me link; enables the 💖 Support button (/donate).
# DONATE_URL=https://paypal.me/yourname
